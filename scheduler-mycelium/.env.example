# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — Template for Scheduler Mycelium backend environment variables
#
#  Copy this file to .env and fill in real values.
#  NEVER commit your actual .env file — it is already in .gitignore.
#
#  On the Hetzner server, place the filled .env file at:
#    /opt/scheduler-mycelium/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── Spring Boot profile ───────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# In Docker Compose the host is the service name 'db', not localhost.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/schedule
SPRING_DATASOURCE_USERNAME=scheduler
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_strong_db_password

# PostgreSQL container credentials (must match SPRING_DATASOURCE_* above)
POSTGRES_DB=schedule
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── JPA / Hibernate ───────────────────────────────────────────────────────────
# Use 'create' only on the very first deployment against a fresh DB.
# Switch to 'validate' for all subsequent deployments.
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# Must be at least 32 characters (64 hex chars = 256 bits = HS256 compliant).
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRATION_MS=86400000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Vercel frontend URL(s)).
# No trailing slashes.
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# ── n8n Webhook URLs ──────────────────────────────────────────────────────────
WEBHOOK_BOOKING_CONFIRMED_URL=https://n8n.myceliumagency.cloud/webhook/email-confirmation
WEBHOOK_BOOKING_CANCELLED_URL=https://n8n.myceliumagency.cloud/webhook/email-cancel

# ── Swagger / OpenAPI ────────────────────────────────────────────────────────
# Set to false to disable Swagger UI in production (optional).
SPRINGDOC_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_SQL=WARN

# ── HikariCP (optional tuning) ────────────────────────────────────────────────
# DB_POOL_MAX_SIZE=20
# DB_POOL_MIN_IDLE=5
# DB_CONNECTION_TIMEOUT_MS=30000
# DB_IDLE_TIMEOUT_MS=600000
# DB_MAX_LIFETIME_MS=1800000
